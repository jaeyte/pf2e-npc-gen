<div class="pf2e-npc-gen-app-content">
  <nav class="pf2e-npc-gen-tabs">
    <div class="tab-item active" data-tab="npc" data-action="switchTab">Character Generator</div>
    <div class="tab-item" data-tab="loot" data-action="switchTab">Loot Generator</div>
    <div class="tab-item" data-tab="ai" data-action="switchTab">AI Generator</div>
  </nav>

  <div class="pf2e-npc-gen-body">
    <!-- NPC Tab -->
    <section class="tab-content active" data-tab="npc">
      <div class="form-group">
        <label for="npc-level">Target Level</label>
        <div class="form-fields">
          <input type="number" name="level" id="npc-level" value="{{level}}" min="-1" max="25">
        </div>
        <p class="notes">Scale statistics to this level (-1 to 25).</p>
      </div>

      <div class="form-group">
        <label for="npc-role">Concept/Role</label>
        <div class="form-fields">
          <select name="role" id="npc-role">
            {{selectOptions roles selected=role}}
          </select>
        </div>
        <p class="notes">Maps to a PF2e class (Barbarian, Rogue, Ranger, Wizard, Fighter).</p>
      </div>

      <div class="form-group">
        <label for="npc-ancestry">Ancestry</label>
        <div class="form-fields">
          <select name="ancestry" id="npc-ancestry">
            <option value="random">Random Ancestry</option>
            {{selectOptions ancestries selected=ancestry}}
          </select>
        </div>
      </div>

      <div class="form-group">
        <label for="npc-theme">Thematic Template</label>
        <div class="form-fields">
          <select name="theme" id="npc-theme">
            {{selectOptions themes selected=theme}}
          </select>
        </div>
        <p class="notes">Apply a mechanical and flavor overlay (e.g., Infernal, Undead).</p>
      </div>

      <div class="form-group">
        <label>
          <input type="checkbox" name="generateEquipment" id="generate-equipment" {{checked generateEquipment}}>
          Generate Standard Equipment
        </label>
      </div>

      <button class="generate-btn" id="generate-npc-btn" data-action="generateNPC">
        <i class="fas fa-hammer"></i> Create Character
      </button>
    </section>

    <!-- Loot Tab -->
    <section class="tab-content" data-tab="loot">
      <div class="form-group">
        <label for="loot-level">Encounter Level</label>
        <div class="form-fields">
          <input type="number" name="lootLevel" id="loot-level" value="{{level}}" min="1" max="25">
        </div>
        <p class="notes">Determines the value and quality of the generated loot.</p>
      </div>

      <div class="form-group">
        <label for="loot-type">Loot Type</label>
        <div class="form-fields">
          <select name="lootType" id="loot-type">
            <option value="hoard">Treasure Hoard (Mixed)</option>
            <option value="consumables">Consumables Only (Potions/Scrolls)</option>
            <option value="permanent">Permanent Items Only</option>
          </select>
        </div>
      </div>

      <button class="generate-btn" id="generate-loot-btn" data-action="generateLoot">
        <i class="fas fa-coins"></i> Generate Loot
      </button>
    </section>

    <!-- AI Generator Tab -->
    <section class="tab-content" data-tab="ai">
      <div class="form-group">
        <label for="ai-concept">NPC Concept</label>
        <div class="form-fields">
          <textarea name="aiConcept" id="ai-concept" rows="3"
            placeholder="e.g. veteran fire cult lieutenant, elven spy master, goblin pirate captain..."></textarea>
        </div>
        <p class="notes">Describe freely. The AI infers role, ancestry, theme, and level.</p>
      </div>

      <div class="form-group">
        <label for="ai-level">Level Override (optional)</label>
        <div class="form-fields">
          <input type="number" name="aiLevel" id="ai-level" placeholder="AI decides" min="-1" max="25">
        </div>
        <p class="notes">Leave blank to let the AI infer the level from your description.</p>
      </div>

      <div class="form-group">
        <label>
          <input type="checkbox" id="ai-generate-equipment" checked>
          Generate Standard Equipment
        </label>
      </div>

      <div class="ai-loading" id="ai-loading" style="display:none;">
        <i class="fas fa-spinner fa-spin"></i> Asking the AI...
      </div>

      <div class="ai-error" id="ai-error" style="display:none;"></div>

      <button class="generate-btn" id="generate-ai-npc-btn" data-action="generateAINPC">
        <i class="fas fa-brain"></i> Generate with AI
      </button>
    </section>
  </div>
</div>
